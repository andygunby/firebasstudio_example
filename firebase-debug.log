[debug] [2025-07-03T12:50:20.894Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    function isOwner(userId) {\n      return request.auth != null && request.auth.uid == userId;\n    }\n    \n    // Checks if the currently authenticated user has the 'isAdmin' flag set to true\n    // in their user profile document.\n    function isAdmin() {\n      // get() performs a document read, which is checked against security rules.\n      // This requires that the rule on `match /users/{userId}` allows the read to happen.\n      return exists(/databases/$(database)/documents/users/$(request.auth.uid))\n        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;\n    }\n\n    match /users/{userId} {\n      // A user can always read their own profile. This is secure and non-circular.\n      allow read: if isOwner(userId);\n      \n      // A user can create their own profile document.\n      allow create: if isOwner(userId);\n      \n      // No one can update or delete user profiles from the client.\n      allow update, delete: if false;\n    }\n\n    match /submissions/{submissionId} {\n      // Any authenticated user can create a submission.\n      allow create: if request.auth != null;\n\n      // An admin can list all submissions. A regular user can list their own submissions.\n      // The `where` clause in the client-side query must match these constraints.\n      allow list: if isAdmin() || (request.query.where.userId == request.auth.uid);\n      \n      // An admin can get/update any submission. A user can get/update their own.\n      allow get, update: if isAdmin() || resource.data.userId == request.auth.uid;\n\n      // No one can delete submissions from the client.\n      allow delete: if false;\n    }\n  }\n}\n"}]}}
