[debug] [2025-07-03T12:52:40.498Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // Checks if the requesting user has an isAdmin:true flag in their user profile.\n    function isAdmin() {\n      // Use exists() to prevent errors if the user document doesn't exist.\n      return exists(/databases/$(database)/documents/users/$(request.auth.uid))\n        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;\n    }\n\n    match /users/{userId} {\n      // Any authenticated user can read their own profile.\n      // This is required for the isAdmin() check to work for all users.\n      allow get: if request.auth != null && request.auth.uid == userId;\n      // Admins can see any user's profile.\n      allow list: if isAdmin();\n      // Only an admin can create or update user roles.\n      allow write: if isAdmin();\n    }\n    \n    match /submissions/{submissionId} {\n      // An authenticated user can create a submission.\n      allow create: if request.auth != null;\n\n      // This single 'read' rule covers both 'get' (single doc) and 'list' (query) operations.\n      // It allows a user to read their own submissions, or an admin to read all submissions.\n      allow read: if request.auth.uid == resource.data.userId || isAdmin();\n\n      // A user can update their own submission, or an admin can update any submission.\n      allow update: if request.auth.uid == resource.data.userId || isAdmin();\n\n      // Only an admin can delete submissions.\n      allow delete: if isAdmin();\n    }\n  }\n}\n"}]}}
