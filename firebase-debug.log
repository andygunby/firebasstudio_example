[debug] [2025-07-03T12:25:52.144Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to check for admin role.\n    // This works because the rule on /users/{userId} allows the 'get' to succeed first.\n    function isAdmin() {\n      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&\n             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;\n    }\n\n    // Rules for the 'users' collection\n    match /users/{userId} {\n      // A user can ALWAYS get their own user document. This is required for isAdmin() to work.\n      allow get: if request.auth.uid == userId;\n\n      // An admin can read and write any user document.\n      // This also lets an admin list all users.\n      allow read, write: if isAdmin();\n    }\n\n    // Rules for the 'submissions' collection\n    match /submissions/{submissionId} {\n      // An admin can read or write any submission.\n      allow read, write: if isAdmin();\n\n      // Authenticated users can create submissions, but only for themselves.\n      allow create: if request.auth.uid == request.resource.data.userId;\n\n      // A user can read or update their own submissions.\n      allow read, update: if request.auth.uid == resource.data.userId;\n    }\n  }\n}\n"}]}}
