[debug] [2025-07-03T13:01:21.255Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // Helper function to robustly check if the currently authenticated user is an admin.\n    function isAdmin() {\n      // It checks that the user is signed in, their user document exists, and the isAdmin flag is true.\n      return request.auth != null &&\n             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&\n             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;\n    }\n\n    match /users/{userId} {\n      // READ: A user can read their own profile. An admin can read any profile.\n      allow read: if request.auth.uid == userId || isAdmin();\n\n      // CREATE: A user can create their own profile document.\n      allow create: if request.auth.uid == userId;\n      \n      // UPDATE: Only an admin can update a user profile to prevent privilege escalation.\n      allow update: if isAdmin();\n    }\n\n    match /submissions/{submissionId} {\n      // CREATE: Any authenticated user can create a submission.\n      allow create: if request.auth != null;\n\n      // GET, UPDATE, DELETE:\n      // An owner can get/update/delete their own document.\n      // An admin can get/update/delete any document.\n      allow get, update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());\n      \n      // LIST (for collection-wide queries):\n      // Only an admin is allowed to list all submissions. This is what the admin dashboard needs.\n      allow list: if isAdmin();\n    }\n  }\n}\n"}]}}
