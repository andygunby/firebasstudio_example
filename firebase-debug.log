[debug] [2025-07-03T12:47:42.335Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to check for admin role.\n    function isUserAdmin() {\n      // This get() call requires a rule on /users/{userId} that allows the current user to read their own document.\n      // We also check that the document exists to prevent errors.\n      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&\n             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;\n    }\n\n    match /users/{userId} {\n      // A user can read their own profile. This allows the isUserAdmin() function to work.\n      allow read: if request.auth.uid == userId;\n      // Only admins can write user profiles.\n      allow write: if isUserAdmin();\n    }\n\n    match /submissions/{submissionId} {\n      // Any authenticated user can create a submission.\n      allow create: if request.auth != null;\n\n      // GET: Users can get their own submissions. Admins can get any.\n      allow get: if request.auth.uid == resource.data.userId || isUserAdmin();\n\n      // LIST: Only admins can list all submissions.\n      // Regular users must use a query constrained by their UID, which is handled by the 'get' rule's logic on each document access.\n      allow list: if isUserAdmin();\n\n      // UPDATE/DELETE: Users can update their own submissions. Admins can update/delete any.\n      allow update: if request.auth.uid == resource.data.userId || isUserAdmin();\n      allow delete: if isUserAdmin();\n    }\n  }\n}\n"}]}}
